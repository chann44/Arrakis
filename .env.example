# Core service config
DB_HOST=postgres
DB_PORT=5432
DB_USER=dev
DB_PASSWORD=dev
DB_NAME=app

REDIS_HOST=redis
REDIS_PORT=6379

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=default

# Public URLs / ingress
TRAEFIK_ACME_EMAIL=ops@example.com
# Optional override. If empty, API auto-detects from request host/IP.
DOMAIN_RECORD_TYPE=A
DOMAIN_RECORD_VALUE=
DOMAIN_TXT_NAME_PREFIX=_tge-challenge
DOMAIN_ROUTER_SYNC_ENABLED=false
TRAEFIK_DYNAMIC_CONFIG_PATH=/etc/traefik/dynamic/custom-domains.yml
FRONTEND_URL=http://localhost:3000

# Optional vulnerability API credentials
GHSA_API_TOKEN=
NVD_API_KEY=

# Optional advanced supply-chain scanning
SUPPLY_CHAIN_ENABLED=false

# Optional AI analyzer (sandboxed dependency analysis)
AI_ANALYZER_ENABLED=false
AI_ANALYZER_MODE=docker
AI_ANALYZER_URL=http://ai-analyzer:8090
AI_ANALYZER_TOKEN=
AI_ANALYZER_DOCKER_IMAGE=arrakis-ai-analyzer:local
AI_ANALYZER_MODEL=gpt-4.1-mini
AI_ANALYZER_MAX_DEPENDENCIES=120
AI_SANDBOX_NETWORK=bridge
AI_SANDBOX_TIMEOUT_SECONDS=180
OPENAI_API_KEY=

# Optional OpenRouter provider (used when OPENROUTER_API_KEY is set)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=arrakis

# Optional Docker daemon logs for System Health
DOCKER_LOGS_ENABLED=false
DOCKER_LOGS_SOCKET_PATH=/var/run/docker.sock
DOCKER_LOGS_INCLUDE_ALL=false
DOCKER_LOGS_NETWORK=tge_dev_net

# Optional image override for self-host compose
# TGE_BACKEND_IMAGE=chann44/tge-backend:latest
# TGE_WEB_IMAGE=chann44/tge-web:latest

# GitHub OAuth / App integration (optional for first boot, needed for GitHub features)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/v1/auth/github/callback
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_APP_INSTALL_URL=
