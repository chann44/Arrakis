FROM node:22-alpine AS builder

WORKDIR /app/apps/web

COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm ci --include=optional \
	&& arch="$(uname -m)" \
	&& if [ "$arch" = "aarch64" ]; then \
		npm install --no-save @rollup/rollup-linux-arm64-musl lightningcss-linux-arm64-musl @tailwindcss/oxide-linux-arm64-musl; \
	else \
		npm install --no-save @rollup/rollup-linux-x64-musl lightningcss-linux-x64-musl @tailwindcss/oxide-linux-x64-musl; \
	fi

COPY apps/web ./
RUN npm run build

FROM node:22-alpine

WORKDIR /app/apps/web

ENV NODE_ENV=production

COPY --from=builder /app/apps/web ./

EXPOSE 3000

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "3000"]
